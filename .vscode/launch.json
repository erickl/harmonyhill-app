// For debugging the react app
{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
      // For debugging the seeder script
      {
        "type": "node",
        "request": "launch",
        "name": "Run Seeder Script",
        "program": "${workspaceFolder}/src/scripts/seeder.mjs",
        "runtimeArgs": ["--experimental-modules"],
        "env": {
          "NODE_ENV": "development",
          "FIRESTORE_EMULATOR_HOST": "localhost:8080",
          "FIREBASE_AUTH_EMULATOR_HOST": "localhost:9099",
          "GCLOUD_PROJECT": "harmonyhill-1",
          "FUNCTIONS_EMULATOR":"true"
        },
        "skipFiles": ["<node_internals>/**"],
        "runtimeExecutable": "/Users/Smexmachine_1/.nvm/versions/node/v20.19.1/bin/node"
      },{ // Debugging the event based fireabse functions
        "type": "node",
        "request": "attach",
        "name": "Debug Event Based Firebase Functions",
        "port": 9229,
        "restart": true,
        "skipFiles": [
          "<node_internals>/**"
        ]
      },{
          "type": "chrome",
          "request": "launch",
          "name": "Launch Chrome against localhost",
          "url": "http://localhost:3000",
          "webRoot": "${workspaceFolder}"
      }
    ]
}
