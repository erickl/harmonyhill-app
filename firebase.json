{
    "firestore": {
        "rules": "firestore.rules"
    },
    "storage": {
        "rules": "storage.rules"
    },
    "hosting": {
        "public": "build",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },  
    "emulators": {
        "firestore": {
            "port": 8080,
            "rules" : "firestore.rules"
        },
        "auth": {
            "port": 9099
        },
        "storage": {
            "port": 9199,
            "rules": "storage.rules"
        },
        "ui": {
            "enabled": true,
            "port": 4000
        }
    }
}